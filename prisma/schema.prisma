model FundDistributionConfig {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  hotWalletId   String    @unique
  HotWallet     HotWallet @relation(fields: [hotWalletId], references: [id], onDelete: Cascade)
  enabled       Boolean   @default(true)
  batchWindowMs Int       @default(300000)
  /// A fund wallet is now purely a funding source: it holds no per-asset
  /// thresholds or top-up sizes. Those live on each hot wallet's
  /// HotWalletLowBalanceRule (the wallet that runs low decides when and how
  /// much). `enabled` toggles this wallet as a funding source; `batchWindowMs`
  /// is its distribution-cycle cadence.
}

/// One top-up requested by a target wallet's per-asset low-balance rule.
///
/// The request remains unassigned until any enabled fund wallet on the same
/// payment source claims it. `assetUnit` uses the rule convention: 'lovelace'
/// for ADA, otherwise policyId + hex asset name.
model FundDistributionRequest {
  id             String                   @id @default(cuid())
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  /// The fund wallet that will pay this top-up. Null while unassigned: a
  /// shortage is recorded per (target, asset) and any fund wallet on the source
  /// can fulfil it, so the wallet is chosen at dispatch (first with funds) and
  /// set atomically with the fund-wallet lock.
  fundWalletId   String?
  FundWallet     HotWallet?               @relation("FundDistributionSource", fields: [fundWalletId], references: [id])
  targetWalletId String
  TargetWallet   HotWallet                @relation("FundDistributionTarget", fields: [targetWalletId], references: [id])
  priority       FundDistributionPriority
  /// Which asset this top-up moves. 'lovelace' for ADA, otherwise
  /// policyId + hex asset name — same convention as HotWalletLowBalanceRule.
  assetUnit      String                   @default("lovelace")
  /// Amount in the asset's own smallest unit. For a native token this is the
  /// token quantity; the ADA that must ride along to satisfy min-UTxO is
  /// computed at build time, not stored here.
  amount         BigInt
  status         FundDistributionStatus   @default(Pending)
  txHash         String?
  error          String?
  batchId        String?
  /// The Transaction row this request was batched into, set atomically with the
  /// fund-wallet lock BEFORE the tx is signed or broadcast. This link is what
  /// lets `reconcileInFlightRequests` observe the outcome that
  /// funding-reconciliation wrote: on promote (chain found the intended hash)
  /// the requests are advanced to Submitted; on RolledBack (TTL provably
  /// elapsed) they are released back to Pending for a fresh build. Without it
  /// an ambiguous submit strands the requests — reconciliation resolves the
  /// Transaction but nothing maps that back to the distribution rows.
  transactionId  String?
  Transaction    Transaction?             @relation("FundDistributionTransaction", fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([fundWalletId, status])
  @@index([status, priority, createdAt])
  // Dedupe is per (target, asset) across ALL fund wallets on the source: a
  // shortage is funded by exactly one wallet regardless of which. An in-flight
  // ADA top-up must not suppress a USDM one to the same wallet — independent
  // shortages.
  @@index([targetWalletId, assetUnit, status])
  @@index([status, updatedAt])
  @@index([transactionId])
}

