generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ApiKey {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  token          String
  tokenHash      String       @unique
  encryptedToken String?
  status         ApiKeyStatus

  // Flag-based permissions (must be set explicitly on create)
  canRead  Boolean
  canPay   Boolean
  canAdmin Boolean

  networkLimit          Network[]
  usageLimited          Boolean             @default(false)
  walletScopeEnabled    Boolean             @default(false)
  deletedAt             DateTime?
  PaymentRequest        PaymentRequest[]
  PurchaseRequest       PurchaseRequest[]
  RemainingUsageCredits UnitValue[]
  CreatedWebhooks       WebhookEndpoint[]
  WalletScopes          ApiKeyWalletScope[]
}

model ApiKeyWalletScope {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  apiKeyId    String
  hotWalletId String
  ApiKey      ApiKey    @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  HotWallet   HotWallet @relation(fields: [hotWalletId], references: [id], onDelete: Cascade)

  @@unique([apiKeyId, hotWalletId])
  @@index([apiKeyId])
  @@index([hotWalletId])
}

model UnitValue {
  id                               String             @id @default(cuid())
  createdAt                        DateTime           @default(now())
  updatedAt                        DateTime           @updatedAt
  unit                             String
  amount                           BigInt
  apiKeyId                         String?
  agentFixedPricingId              String?
  paymentRequestId                 String?
  purchaseRequestId                String?
  buyerWithdrawnPaymentRequestId   String?
  buyerWithdrawnPurchaseRequestId  String?
  sellerWithdrawnPaymentRequestId  String?
  sellerWithdrawnPurchaseRequestId String?
  AgentFixedPricing                AgentFixedPricing? @relation(fields: [agentFixedPricingId], references: [id])
  ApiKey                           ApiKey?            @relation(fields: [apiKeyId], references: [id])
  BuyerWithdrawnPaymentRequest     PaymentRequest?    @relation("BuyerWithdrawnPaymentRequest", fields: [buyerWithdrawnPaymentRequestId], references: [id])
  BuyerWithdrawnPurchaseRequest    PurchaseRequest?   @relation("BuyerWithdrawnPurchaseRequest", fields: [buyerWithdrawnPurchaseRequestId], references: [id])
  PaymentRequest                   PaymentRequest?    @relation(fields: [paymentRequestId], references: [id])
  PurchaseRequest                  PurchaseRequest?   @relation(fields: [purchaseRequestId], references: [id])
  SellerWithdrawnPaymentRequest    PaymentRequest?    @relation("SellerWithdrawnPaymentRequest", fields: [sellerWithdrawnPaymentRequestId], references: [id])
  SellerWithdrawnPurchaseRequest   PurchaseRequest?   @relation("SellerWithdrawnPurchaseRequest", fields: [sellerWithdrawnPurchaseRequestId], references: [id])
}

model HotWallet {
  id                       String                    @id @default(cuid())
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  walletVkey               String                    @unique
  walletAddress            String
  type                     HotWalletType
  secretId                 String
  collectionAddress        String?
  pendingTransactionId     String?                   @unique
  pendingSwapTransactionId String?                   @unique
  paymentSourceId          String
  lockedAt                 DateTime?
  note                     String?
  deletedAt                DateTime?
  PaymentSource            PaymentSource             @relation(fields: [paymentSourceId], references: [id], onDelete: Cascade)
  PendingTransaction       Transaction?              @relation(fields: [pendingTransactionId], references: [id])
  PendingSwapTransaction   SwapTransaction?          @relation(fields: [pendingSwapTransactionId], references: [id])
  SwapTransactionHistory   SwapTransaction[]         @relation("SwapTransactionHistory")
  Secret                   WalletSecret              @relation(fields: [secretId], references: [id])
  PaymentRequest           PaymentRequest[]
  PurchaseRequest          PurchaseRequest[]
  RegistryRequest          RegistryRequest[]         @relation("RegistryRequestMintingWallet")
  RecipientRegistryRequest RegistryRequest[]         @relation("RegistryRequestRecipientWallet")
  DeregistrationRequests   RegistryRequest[]         @relation("RegistryRequestDeregistrationWallet")
  InboxAgentRegistrationRequests          InboxAgentRegistrationRequest[] @relation("InboxAgentRegistrationRequestMintingWallet")
  RecipientInboxAgentRegistrationRequests InboxAgentRegistrationRequest[] @relation("InboxAgentRegistrationRequestRecipientWallet")
  InboxDeregistrationRequests             InboxAgentRegistrationRequest[] @relation("InboxAgentRegistrationRequestDeregistrationWallet")
  apiKeyWalletScopes       ApiKeyWalletScope[]
  LimitedPurchaseRequests  PurchaseRequest[]         @relation("HotWalletLimit")
  LowBalanceRules          HotWalletLowBalanceRule[]
}

model HotWalletLowBalanceRule {
  id              String           @id @default(cuid())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  hotWalletId     String
  assetUnit       String
  thresholdAmount BigInt
  enabled         Boolean          @default(true)
  status          LowBalanceStatus @default(Unknown)
  lastKnownAmount BigInt?
  lastCheckedAt   DateTime?
  lastAlertedAt   DateTime?
  HotWallet       HotWallet        @relation(fields: [hotWalletId], references: [id], onDelete: Cascade)

  @@unique([hotWalletId, assetUnit])
  @@index([hotWalletId, enabled])
  @@index([enabled, status])
}

model Transaction {
  id                       String            @id @default(cuid())
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  txHash                   String?
  status                   TransactionStatus
  confirmations            Int?
  lastCheckedAt            DateTime?
  fees                     BigInt?
  blockHeight              Int?
  blockTime                Int?
  outputAmount             String?           @db.Text
  utxoCount                Int?
  withdrawalCount          Int?
  assetMintOrBurnCount     Int?
  redeemerCount            Int?
  validContract            Boolean?
  paymentRequestHistoryId  String?
  purchaseRequestHistoryId String?
  previousOnChainState     OnChainState?
  newOnChainState          OnChainState?
  BlocksWallet             HotWallet?
  PaymentRequestCurrent    PaymentRequest?   @relation("CurrentPaymentTransaction")
  PurchaseRequestCurrent   PurchaseRequest?  @relation("CurrentPurchaseTransaction")
  RegistryRequest          RegistryRequest[]
  InboxAgentRegistrationRequest InboxAgentRegistrationRequest[]
  PaymentRequestHistory    PaymentRequest?   @relation("PaymentTransactionHistory", fields: [paymentRequestHistoryId], references: [id])
  PurchaseRequestHistory   PurchaseRequest?  @relation("PurchaseTransactionHistory", fields: [purchaseRequestHistoryId], references: [id])
}

model SwapTransaction {
  id               String            @id @default(cuid())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  txHash           String?
  status           TransactionStatus
  swapStatus       SwapStatus        @default(OrderPending)
  confirmations    Int?
  lastCheckedAt    DateTime?
  fromPolicyId     String
  fromAssetName    String
  fromAmount       String
  toPolicyId       String
  toAssetName      String
  poolId           String
  slippage         Float?
  cancelTxHash     String?
  orderOutputIndex Int?
  hotWalletId      String?
  BlocksWallet     HotWallet?
  HotWallet        HotWallet?        @relation("SwapTransactionHistory", fields: [hotWalletId], references: [id])
}

model WalletSecret {
  id                String      @id @default(cuid())
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  encryptedMnemonic String
  HotWallet         HotWallet[]
}

model WalletBase {
  id              String            @id @default(cuid())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  walletVkey      String
  note            String?
  type            WalletType
  paymentSourceId String
  walletAddress   String            @default("")
  PaymentRequest  PaymentRequest[]
  PurchaseRequest PurchaseRequest[]
  PaymentSource   PaymentSource     @relation(fields: [paymentSourceId], references: [id])

  @@unique([paymentSourceId, walletVkey, walletAddress, type])
}

model RegistryRequest {
  id                             String            @id @default(cuid())
  createdAt                      DateTime          @default(now())
  updatedAt                      DateTime          @updatedAt
  lastCheckedAt                  DateTime?
  paymentSourceId                String
  smartContractWalletId          String
  recipientHotWalletId           String?
  deregistrationHotWalletId      String?
  sendFundingLovelace            BigInt?
  name                           String
  apiBaseUrl                     String
  capabilityName                 String?
  capabilityVersion              String?
  description                    String?
  privacyPolicy                  String?
  terms                          String?
  other                          String?
  authorName                     String
  authorContactEmail             String?
  authorContactOther             String?
  authorOrganization             String?
  metadataVersion                Int
  tags                           String[]
  agentPricingId                 String            @unique
  agentIdentifier                String?           @unique
  state                          RegistrationState
  registrationStateLastChangedAt DateTime          @default(now())
  currentTransactionId           String?
  error                          String?
  paymentType                    PaymentType       @default(Web3CardanoV1)
  ExampleOutputs                 ExampleOutput[]
  Pricing                        AgentPricing      @relation(fields: [agentPricingId], references: [id])
  CurrentTransaction             Transaction?      @relation(fields: [currentTransactionId], references: [id])
  PaymentSource                  PaymentSource     @relation(fields: [paymentSourceId], references: [id])
  SmartContractWallet            HotWallet         @relation("RegistryRequestMintingWallet", fields: [smartContractWalletId], references: [id])
  RecipientWallet                HotWallet?        @relation("RegistryRequestRecipientWallet", fields: [recipientHotWalletId], references: [id])
  DeregistrationHotWallet        HotWallet?        @relation("RegistryRequestDeregistrationWallet", fields: [deregistrationHotWalletId], references: [id])

  @@index([recipientHotWalletId])
  @@index([deregistrationHotWalletId])
}

model InboxAgentRegistrationRequest {
  id                             String            @id @default(cuid())
  createdAt                      DateTime          @default(now())
  updatedAt                      DateTime          @updatedAt
  lastCheckedAt                  DateTime?
  paymentSourceId                String
  smartContractWalletId          String
  recipientHotWalletId           String?
  deregistrationHotWalletId      String?
  sendFundingLovelace            BigInt?
  name                           String
  description                    String?
  agentSlug                      String
  metadataVersion                Int
  agentIdentifier                String?           @unique
  state                          RegistrationState
  registrationStateLastChangedAt DateTime          @default(now())
  currentTransactionId           String?
  error                          String?
  CurrentTransaction             Transaction?      @relation(fields: [currentTransactionId], references: [id])
  PaymentSource                  PaymentSource     @relation(fields: [paymentSourceId], references: [id])
  SmartContractWallet            HotWallet         @relation("InboxAgentRegistrationRequestMintingWallet", fields: [smartContractWalletId], references: [id])
  RecipientWallet                HotWallet?        @relation("InboxAgentRegistrationRequestRecipientWallet", fields: [recipientHotWalletId], references: [id])
  DeregistrationHotWallet        HotWallet?        @relation("InboxAgentRegistrationRequestDeregistrationWallet", fields: [deregistrationHotWalletId], references: [id])

  @@index([recipientHotWalletId])
  @@index([deregistrationHotWalletId])
}

model ExampleOutput {
  id                String           @id @default(cuid())
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  name              String
  mimeType          String
  url               String
  registryRequestId String?
  RegistryRequest   RegistryRequest? @relation(fields: [registryRequestId], references: [id])
}

model AgentPricing {
  id                  String             @id @default(cuid())
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  pricingType         PricingType
  agentFixedPricingId String?            @unique
  FixedPricing        AgentFixedPricing? @relation(fields: [agentFixedPricingId], references: [id])
  RegistryRequest     RegistryRequest?
}

model AgentFixedPricing {
  id           String        @id @default(cuid())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  AgentPricing AgentPricing?
  Amounts      UnitValue[]
}

model PaymentRequest {
  id                                            String              @id @default(cuid())
  createdAt                                     DateTime            @default(now())
  updatedAt                                     DateTime            @updatedAt
  lastCheckedAt                                 DateTime?
  paymentSourceId                               String
  smartContractWalletId                         String?
  buyerWalletId                                 String?
  nextActionId                                  String              @unique
  nextActionLastChangedAt                       DateTime            @default(now())
  metadata                                      String?
  pricingType                                   PricingType         @default(Fixed)
  blockchainIdentifier                          String              @unique
  submitResultTime                              BigInt
  unlockTime                                    BigInt
  externalDisputeUnlockTime                     BigInt
  inputHash                                     String
  resultHash                                    String?
  onChainState                                  OnChainState?
  onChainStateOrResultLastChangedAt             DateTime            @default(now())
  nextActionOrOnChainStateOrResultLastChangedAt DateTime            @default(now())
  sellerCoolDownTime                            BigInt
  buyerCoolDownTime                             BigInt
  requestedById                                 String
  currentTransactionId                          String?             @unique
  collateralReturnLovelace                      BigInt?
  payByTime                                     BigInt?
  BuyerWallet                                   WalletBase?         @relation(fields: [buyerWalletId], references: [id])
  CurrentTransaction                            Transaction?        @relation("CurrentPaymentTransaction", fields: [currentTransactionId], references: [id])
  NextAction                                    PaymentActionData   @relation("NextAction", fields: [nextActionId], references: [id])
  ActionHistory                                 PaymentActionData[] @relation("PaymentActionHistory")
  PaymentSource                                 PaymentSource       @relation("PaymentRequestPaymentSource", fields: [paymentSourceId], references: [id], onDelete: Cascade)
  totalBuyerCardanoFees                         BigInt              @default(0)
  totalSellerCardanoFees                        BigInt              @default(0)
  requestedBy                                   ApiKey              @relation(fields: [requestedById], references: [id])
  SmartContractWallet                           HotWallet?          @relation(fields: [smartContractWalletId], references: [id])
  TransactionHistory                            Transaction[]       @relation("PaymentTransactionHistory")
  WithdrawnForBuyer                             UnitValue[]         @relation("BuyerWithdrawnPaymentRequest")
  RequestedFunds                                UnitValue[]
  WithdrawnForSeller                            UnitValue[]         @relation("SellerWithdrawnPaymentRequest")
  InvoiceItem                                   InvoiceItem[]
  invoiceBase                                   InvoiceBase?        @relation(fields: [invoiceBaseId], references: [id])
  invoiceBaseId                                 String?

  @@index([nextActionLastChangedAt])
  @@index([nextActionLastChangedAt, id])
  @@index([onChainStateOrResultLastChangedAt])
  @@index([onChainStateOrResultLastChangedAt, id])
  @@index([nextActionOrOnChainStateOrResultLastChangedAt], map: "PaymentRequest_combinedLastChangedAt_idx")
  @@index([nextActionOrOnChainStateOrResultLastChangedAt, id], map: "PaymentRequest_combinedLastChangedAt_id_idx")
  @@index([paymentSourceId, createdAt])
  @@index([paymentSourceId, onChainState])
  @@index([paymentSourceId, payByTime])
}

model PaymentActionData {
  id                      String            @id @default(cuid())
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  requestedAction         PaymentAction
  resultHash              String?
  submittedTxHash         String?
  errorType               PaymentErrorType?
  errorNote               String?
  PaymentRequestCurrent   PaymentRequest?   @relation("NextAction")
  paymentRequestHistoryId String?
  PaymentRequestHistory   PaymentRequest?   @relation("PaymentActionHistory", fields: [paymentRequestHistoryId], references: [id])
}

model PurchaseRequest {
  id                                            String               @id @default(cuid())
  createdAt                                     DateTime             @default(now())
  updatedAt                                     DateTime             @updatedAt
  lastCheckedAt                                 DateTime?
  paymentSourceId                               String
  sellerWalletId                                String
  smartContractWalletId                         String?
  metadata                                      String?
  pricingType                                   PricingType          @default(Fixed)
  blockchainIdentifier                          String               @unique
  submitResultTime                              BigInt
  unlockTime                                    BigInt
  externalDisputeUnlockTime                     BigInt
  inputHash                                     String
  resultHash                                    String?
  onChainState                                  OnChainState?
  onChainStateOrResultLastChangedAt             DateTime             @default(now())
  sellerCoolDownTime                            BigInt
  buyerCoolDownTime                             BigInt
  totalBuyerCardanoFees                         BigInt               @default(0)
  totalSellerCardanoFees                        BigInt               @default(0)
  nextActionId                                  String               @unique
  nextActionLastChangedAt                       DateTime             @default(now())
  nextActionOrOnChainStateOrResultLastChangedAt DateTime             @default(now())
  requestedById                                 String
  currentTransactionId                          String?              @unique
  collateralReturnLovelace                      BigInt?
  payByTime                                     BigInt?
  CurrentTransaction                            Transaction?         @relation("CurrentPurchaseTransaction", fields: [currentTransactionId], references: [id])
  NextAction                                    PurchaseActionData   @relation("NextAction", fields: [nextActionId], references: [id])
  ActionHistory                                 PurchaseActionData[] @relation("PurchaseActionHistory")
  PaymentSource                                 PaymentSource        @relation("PurchaseRequestPaymentSource", fields: [paymentSourceId], references: [id], onDelete: Cascade)
  requestedBy                                   ApiKey               @relation(fields: [requestedById], references: [id])
  SellerWallet                                  WalletBase           @relation(fields: [sellerWalletId], references: [id], onDelete: Cascade)
  SmartContractWallet                           HotWallet?           @relation(fields: [smartContractWalletId], references: [id])
  isLimitedToHotWallets                         Boolean
  HotWalletLimit                                HotWallet[]          @relation("HotWalletLimit")
  TransactionHistory                            Transaction[]        @relation("PurchaseTransactionHistory")
  WithdrawnForBuyer                             UnitValue[]          @relation("BuyerWithdrawnPurchaseRequest")
  PaidFunds                                     UnitValue[]
  WithdrawnForSeller                            UnitValue[]          @relation("SellerWithdrawnPurchaseRequest")

  @@index([nextActionLastChangedAt])
  @@index([nextActionLastChangedAt, id])
  @@index([onChainStateOrResultLastChangedAt])
  @@index([onChainStateOrResultLastChangedAt, id])
  @@index([nextActionOrOnChainStateOrResultLastChangedAt], map: "PurchaseRequest_combinedLastChangedAt_idx")
  @@index([nextActionOrOnChainStateOrResultLastChangedAt, id], map: "PurchaseRequest_combinedLastChangedAt_id_idx")
  @@index([paymentSourceId, createdAt])
  @@index([paymentSourceId, onChainState])
  @@index([paymentSourceId, payByTime])
}

model PurchaseActionData {
  id                       String             @id @default(cuid())
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  requestedAction          PurchasingAction
  submittedTxHash          String?
  errorType                PurchaseErrorType?
  errorNote                String?
  PurchaseRequestCurrent   PurchaseRequest?   @relation("NextAction")
  purchaseRequestHistoryId String?
  PurchaseRequestHistory   PurchaseRequest?   @relation("PurchaseActionHistory", fields: [purchaseRequestHistoryId], references: [id])
}

model PaymentSourceIdentifiers {
  id              String        @id @default(cuid())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  txHash          String        @unique
  paymentSourceId String
  PaymentSource   PaymentSource @relation(fields: [paymentSourceId], references: [id])
}

model PaymentSource {
  id                       String                     @id @default(cuid())
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  network                  Network
  lastCheckedAt            DateTime?
  lastIdentifierChecked    String?
  syncInProgress           Boolean                    @default(false)
  smartContractAddress     String
  adminWalletId            String
  feeRatePermille          Int
  cooldownTime             Int
  paymentSourceConfigId    String                     @unique
  deletedAt                DateTime?
  policyId                 String?
  disablePaymentAt         DateTime?
  disableSyncAt            DateTime?
  AdminWallets             AdminWallet[]              @relation("AdminWallets")
  HotWallets               HotWallet[]
  PaymentRequests          PaymentRequest[]           @relation("PaymentRequestPaymentSource")
  FeeReceiverNetworkWallet AdminWallet                @relation("FeeReceiverNetworkWallet", fields: [adminWalletId], references: [id], onDelete: Cascade)
  PaymentSourceConfig      PaymentSourceConfig        @relation(fields: [paymentSourceConfigId], references: [id])
  PaymentSourceIdentifiers PaymentSourceIdentifiers[]
  PurchaseRequests         PurchaseRequest[]          @relation("PurchaseRequestPaymentSource")
  RegistryRequest          RegistryRequest[]
  InboxAgentRegistrationRequests InboxAgentRegistrationRequest[]
  WalletBases              WalletBase[]
  WebhookEndpoints         WebhookEndpoint[]

  @@unique([network, smartContractAddress])
  @@unique([network, policyId])
}

model AdminWallet {
  id                       String          @id @default(cuid())
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  walletAddress            String
  paymentSourceAdminId     String?
  order                    Int
  PaymentSourceAdmin       PaymentSource?  @relation("AdminWallets", fields: [paymentSourceAdminId], references: [id])
  PaymentSourceFeeReceiver PaymentSource[] @relation("FeeReceiverNetworkWallet")
}

model PaymentSourceConfig {
  id                String         @id @default(cuid())
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  rpcProviderApiKey String
  rpcProvider       RPCProvider
  PaymentSource     PaymentSource?
}

enum ApiKeyStatus {
  Active
  Revoked
}

enum HotWalletType {
  Selling
  Purchasing
}

enum WalletType {
  Buyer
  Seller
}

enum RegistrationState {
  RegistrationRequested
  RegistrationInitiated
  RegistrationConfirmed
  RegistrationFailed
  DeregistrationRequested
  DeregistrationInitiated
  DeregistrationConfirmed
  DeregistrationFailed
}

enum PricingType {
  Fixed
  Free
  Dynamic
}

enum PaymentErrorType {
  NetworkError
  Unknown
}

enum PurchaseErrorType {
  NetworkError
  InsufficientFunds
  Unknown
}

enum PaymentType {
  Web3CardanoV1
  None
}

enum TransactionStatus {
  Pending
  Confirmed
  FailedViaTimeout
  FailedViaManualReset
  RolledBack
}

enum SwapStatus {
  OrderPending
  OrderConfirmed
  CancelPending
  CancelConfirmed
  Completed
  OrderSubmitTimeout
  CancelSubmitTimeout
}

enum OnChainState {
  FundsLocked
  FundsOrDatumInvalid
  ResultSubmitted
  RefundRequested
  Disputed
  Withdrawn
  RefundWithdrawn
  DisputedWithdrawn
}

enum PaymentAction {
  None
  Ignore
  WaitingForManualAction
  WaitingForExternalAction
  SubmitResultRequested
  SubmitResultInitiated
  WithdrawRequested
  WithdrawInitiated
  AuthorizeRefundRequested
  AuthorizeRefundInitiated
}

enum PurchasingAction {
  None
  Ignore
  WaitingForManualAction
  WaitingForExternalAction
  FundsLockingRequested
  FundsLockingInitiated
  SetRefundRequestedRequested
  SetRefundRequestedInitiated
  UnSetRefundRequestedRequested
  UnSetRefundRequestedInitiated
  WithdrawRefundRequested
  WithdrawRefundInitiated
}

model InvoiceBase {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyerWalletVkey  String
  sellerWalletVkey String
  invoiceMonth     Int
  invoiceYear      Int

  InvoiceRevisions InvoiceRevision[]
  invoiceId        String            @unique

  coveredPaymentRequests PaymentRequest[]

  @@unique([buyerWalletVkey, sellerWalletVkey, invoiceYear, invoiceMonth])
  @@index([invoiceYear, invoiceMonth, createdAt])
}

model InvoiceRevision {
  id             String        @id @default(cuid())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  invoiceBaseId  String
  InvoiceBase    InvoiceBase   @relation(fields: [invoiceBaseId], references: [id])
  InvoiceItems   InvoiceItem[]
  revisionNumber Int           @default(0)

  currencyShortId String

  // Invoice metadata
  invoiceTitle       String
  invoiceDescription String?
  invoiceDate        DateTime
  reverseCharge      Boolean
  invoiceGreetings   String?
  invoiceClosing     String?
  invoiceSignature   String?
  invoiceLogo        String?
  invoiceFooter      String?
  invoiceTerms       String?
  invoicePrivacy     String?

  // Global formatting options
  language           String?
  localizationFormat String

  // Seller information
  sellerCountry       String
  sellerCity          String
  sellerZipCode       String
  sellerStreet        String
  sellerStreetNumber  String
  sellerEmail         String?
  sellerPhone         String?
  sellerName          String?
  sellerCompanyName   String?
  sellerVatNumber     String?
  sellerWalletAddress String?

  // Buyer information
  buyerCountry       String
  buyerCity          String
  buyerZipCode       String
  buyerStreet        String
  buyerStreetNumber  String
  buyerEmail         String?
  buyerPhone         String?
  buyerName          String?
  buyerCompanyName   String?
  buyerVatNumber     String?
  buyerWalletAddress String?

  generatedPDFInvoice       Bytes
  generatedInvoiceUpdatedAt DateTime

  isCancelled                        Boolean   @default(false)
  cancellationReason                 String?
  cancellationDate                   DateTime?
  cancellationId                     String?   @unique
  generatedCancelledInvoice          Bytes?
  generatedCancelledInvoiceUpdatedAt DateTime?

  @@unique([invoiceBaseId, revisionNumber])
}

model InvoicePrefix {
  id    String @id
  count Int    @default(0)
}

model InvoiceItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name                   String
  quantity               Decimal
  pricePerUnitWithoutVat Decimal
  vatRate                Decimal
  vatAmount              Decimal
  totalAmount            Decimal
  decimals               Int
  conversionFactor       Decimal
  convertedUnit          String
  conversionDate         DateTime

  ReferencedPayment   PaymentRequest? @relation(fields: [referencedPaymentId], references: [id])
  referencedPaymentId String?

  InvoiceRevision   InvoiceRevision @relation(fields: [invoiceRevisionId], references: [id])
  invoiceRevisionId String
}

enum Network {
  Preprod
  Mainnet
}

enum RPCProvider {
  Blockfrost
}

enum LowBalanceStatus {
  Unknown
  Healthy
  Low
}

// Webhook models
model WebhookEndpoint {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  url       String
  urlHash   String?
  authToken String?
  format    WebhookFormat @default(EXTENDED)
  events    WebhookEventType[]
  name      String?

  PaymentSource   PaymentSource? @relation(fields: [paymentSourceId], references: [id], onDelete: Cascade)
  paymentSourceId String?

  CreatedByApiKey   ApiKey? @relation(fields: [createdByApiKeyId], references: [id], onDelete: SetNull)
  createdByApiKeyId String?

  isActive            Boolean   @default(true)
  failureCount        Int       @default(0)
  consecutiveFailures Int       @default(0)
  lastSuccessAt       DateTime?
  disabledAt          DateTime?

  WebhookDeliveries WebhookDelivery[]

  @@index([urlHash, paymentSourceId, format])
}

model WebhookDelivery {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  WebhookEndpoint   WebhookEndpoint @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)
  webhookEndpointId String

  eventType WebhookEventType
  payload   Json
  entityId  String?

  status      WebhookDeliveryStatus @default(Pending)
  attempts    Int                   @default(0)
  maxAttempts Int                   @default(3)
  nextRetryAt DateTime?

  responseCode Int?
  errorMessage String?
  deliveredAt  DateTime?
  durationMs   Int?
}

enum WebhookEventType {
  PURCHASE_ON_CHAIN_STATUS_CHANGED
  PAYMENT_ON_CHAIN_STATUS_CHANGED
  PURCHASE_ON_ERROR
  PAYMENT_ON_ERROR
  WALLET_LOW_BALANCE
}

enum WebhookFormat {
  EXTENDED
  SLACK
  GOOGLE_CHAT
  DISCORD
}

enum WebhookDeliveryStatus {
  Pending
  Success
  Failed
  Retrying
  Cancelled
}
