  nextActionOrOnChainStateOrResultLastChangedAt DateTime            @default(now())
  sellerCoolDownTime                            BigInt
  buyerCoolDownTime                             BigInt
  requestedById                                 String
  // Not @unique: V2 batch transactions reference one shared Transaction row from N PaymentRequests.
  // Uniqueness was a leftover from the V1 single-item flow; dropping it allows
  // a multi-redeemer batch tx to be referenced once from each participating request.
  currentTransactionId                          String?
  /// Exact live Hydra escrow output currently accepted for this request.
  /// Kept separately because an L2 action replaces CurrentTransaction with its
  /// pending tx before that tx spends this prior output.
  currentHydraUtxoTxHash                        String?
  currentHydraUtxoOutputIndex                   Int?
  /// Canonical one-row-per-unit value of the exact accepted Hydra output.
  currentHydraUtxoValue                         Json?
  /// A confirmed terminal spend whose CIP-8 admin payload could not be
  /// independently authenticated from snapshot-bound evidence.
  unresolvedHydraTerminalTxHash                 String?
  unresolvedHydraTerminalReason                 String?
  /// Exact L1 output created by the authenticated Hydra fanout for this
  /// surviving escrow. Reconciliation uses all three as an atomic CAS marker
  /// while moving ownership to L1, then clears them in the same transaction.
  hydraFanoutHandoffHeadId                      String?
  hydraFanoutHandoffTxHash                      String?
  hydraFanoutHandoffOutputIndex                 Int?
  collateralReturnLovelace                      BigInt?
  payByTime                                     BigInt?
  buyerReturnAddress                            String?
  sellerReturnAddress                           String?
  BuyerWallet                                   WalletBase?         @relation(fields: [buyerWalletId], references: [id])
  CurrentTransaction                            Transaction?        @relation("CurrentPaymentTransaction", fields: [currentTransactionId], references: [id])
  NextAction                                    PaymentActionData   @relation("NextAction", fields: [nextActionId], references: [id])
  ActionHistory                                 PaymentActionData[] @relation("PaymentActionHistory")
  PaymentSource                                 PaymentSource       @relation("PaymentRequestPaymentSource", fields: [paymentSourceId], references: [id], onDelete: Cascade)
  totalBuyerCardanoFees                         BigInt              @default(0)
  totalSellerCardanoFees                        BigInt              @default(0)
  requestedBy                                   ApiKey              @relation(fields: [requestedById], references: [id])
  SmartContractWallet                           HotWallet?          @relation(fields: [smartContractWalletId], references: [id])
  TransactionHistory                            Transaction[]       @relation("PaymentTransactionHistory")
  WithdrawnForBuyer                             UnitValue[]         @relation("BuyerWithdrawnPaymentRequest")
  RequestedFunds                                UnitValue[]
  WithdrawnForSeller                            UnitValue[]         @relation("SellerWithdrawnPaymentRequest")
  InvoiceItem                                   InvoiceItem[]
  invoiceBase                                   InvoiceBase?        @relation(fields: [invoiceBaseId], references: [id])
  invoiceBaseId                                 String?

  /// Which blockchain layer this request targets
  layer TransactionLayer @default(L1)

  /// Optional caller override for L1 vs Hydra (L2) routing. L1 = always lock on
  /// L1 even if a Hydra head is open; L2 = require an open head or fail (never
  /// silently fall back to L1). Null = auto (L2 if a head is available, else L1).
  forceLayer TransactionLayer?

  @@index([nextActionLastChangedAt])
  @@index([nextActionLastChangedAt, id])
  @@index([onChainStateOrResultLastChangedAt])
  @@index([onChainStateOrResultLastChangedAt, id])
  @@index([nextActionOrOnChainStateOrResultLastChangedAt], map: "PaymentRequest_combinedLastChangedAt_idx")
  @@index([nextActionOrOnChainStateOrResultLastChangedAt, id], map: "PaymentRequest_combinedLastChangedAt_id_idx")
  // List endpoints sort by createdAt DESC with cursor pagination; without this
  // every filtered page sorts the full table.
  @@index([createdAt, id])
  @@index([paymentSourceId, createdAt])
  @@index([paymentSourceId, onChainState])
  @@index([paymentSourceId, payByTime])
  @@index([currentTransactionId])
  @@index([currentHydraUtxoTxHash])
  @@index([unresolvedHydraTerminalTxHash])
  @@index([hydraFanoutHandoffHeadId])
  @@index([layer])
}

