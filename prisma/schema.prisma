generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ApiKey {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  token          String
  tokenHash      String       @unique
  encryptedToken String?
  status         ApiKeyStatus

  // Flag-based permissions (must be set explicitly on create)
  canRead  Boolean
  canPay   Boolean
  canAdmin Boolean

  /// CAIP-2 chain identifiers this API key may access. Cardano public APIs
  /// remain wire-compatible with `Network` enum values and translate
  /// Mainnet/Preprod to cardano:mainnet/cardano:preprod at the auth boundary.
  networkLimit                  String[]
  usageLimited                  Boolean                         @default(false)
  walletScopeEnabled            Boolean                         @default(false)
  deletedAt                     DateTime?
  PaymentRequest                PaymentRequest[]
  PurchaseRequest               PurchaseRequest[]
  RegistryRequest               RegistryRequest[]
  RemainingUsageCredits         UnitValue[]
  CreatedWebhooks               WebhookEndpoint[]
  WalletScopes                  ApiKeyWalletScope[]
  InboxAgentRegistrationRequest InboxAgentRegistrationRequest[]
  CreatedX402Wallets            X402EvmWallet[]
  X402WalletBudgets             X402WalletBudget[]              @relation("X402WalletBudgetGrantee")
  CreatedX402WalletBudgets      X402WalletBudget[]              @relation("X402WalletBudgetCreatedBy")
  CreatedX402Networks           X402Network[]
  X402PaymentAttempts           X402PaymentAttempt[]
}

model ApiKeyWalletScope {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  apiKeyId    String
  hotWalletId String
  ApiKey      ApiKey    @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  HotWallet   HotWallet @relation(fields: [hotWalletId], references: [id], onDelete: Cascade)

  @@unique([apiKeyId, hotWalletId])
  @@index([apiKeyId])
  @@index([hotWalletId])
}

model UnitValue {
  id                               String             @id @default(cuid())
  createdAt                        DateTime           @default(now())
  updatedAt                        DateTime           @updatedAt
  unit                             String
  amount                           BigInt
  apiKeyId                         String?
  agentFixedPricingId              String?
  paymentRequestId                 String?
  purchaseRequestId                String?
  buyerWithdrawnPaymentRequestId   String?
  buyerWithdrawnPurchaseRequestId  String?
  sellerWithdrawnPaymentRequestId  String?
  sellerWithdrawnPurchaseRequestId String?
  AgentFixedPricing                AgentFixedPricing? @relation(fields: [agentFixedPricingId], references: [id])
  ApiKey                           ApiKey?            @relation(fields: [apiKeyId], references: [id])
  BuyerWithdrawnPaymentRequest     PaymentRequest?    @relation("BuyerWithdrawnPaymentRequest", fields: [buyerWithdrawnPaymentRequestId], references: [id])
  BuyerWithdrawnPurchaseRequest    PurchaseRequest?   @relation("BuyerWithdrawnPurchaseRequest", fields: [buyerWithdrawnPurchaseRequestId], references: [id])
  PaymentRequest                   PaymentRequest?    @relation(fields: [paymentRequestId], references: [id])
  PurchaseRequest                  PurchaseRequest?   @relation(fields: [purchaseRequestId], references: [id])
  SellerWithdrawnPaymentRequest    PaymentRequest?    @relation("SellerWithdrawnPaymentRequest", fields: [sellerWithdrawnPaymentRequestId], references: [id])
  SellerWithdrawnPurchaseRequest   PurchaseRequest?   @relation("SellerWithdrawnPurchaseRequest", fields: [sellerWithdrawnPurchaseRequestId], references: [id])
}

model HotWallet {
  id                                      String                          @id @default(cuid())
  createdAt                               DateTime                        @default(now())
  updatedAt                               DateTime                        @updatedAt
  /// Unique among ACTIVE wallets only, via the partial database index in
  /// 20260717000001_scope_wallet_vkey_uniqueness_to_active (Prisma cannot
  /// express predicated indexes). A global unique made a soft-deleted fund
  /// wallet's mnemonic permanently unregisterable.
  walletVkey                              String
  walletAddress                           String
  type                                    HotWalletType
  secretId                                String
  collectionAddress                       String?
  pendingTransactionId                    String?                         @unique
  pendingSwapTransactionId                String?                         @unique
  paymentSourceId                         String
  lockedAt                                DateTime?
  note                                    String?
  deletedAt                               DateTime?
  PaymentSource                           PaymentSource                   @relation(fields: [paymentSourceId], references: [id], onDelete: Cascade)
  PendingTransaction                      Transaction?                    @relation(fields: [pendingTransactionId], references: [id])
  PendingSwapTransaction                  SwapTransaction?                @relation(fields: [pendingSwapTransactionId], references: [id])
  SwapTransactionHistory                  SwapTransaction[]               @relation("SwapTransactionHistory")
  FundTransferHistory                     WalletFundTransfer[]            @relation("FundTransferHistory")
  Secret                                  WalletSecret                    @relation(fields: [secretId], references: [id])
  PaymentRequest                          PaymentRequest[]
  PurchaseRequest                         PurchaseRequest[]
  RegistryRequest                         RegistryRequest[]               @relation("RegistryRequestMintingWallet")
  RecipientRegistryRequest                RegistryRequest[]               @relation("RegistryRequestRecipientWallet")
  DeregistrationRequests                  RegistryRequest[]               @relation("RegistryRequestDeregistrationWallet")
  InboxAgentRegistrationRequests          InboxAgentRegistrationRequest[] @relation("InboxAgentRegistrationRequestMintingWallet")
  RecipientInboxAgentRegistrationRequests InboxAgentRegistrationRequest[] @relation("InboxAgentRegistrationRequestRecipientWallet")
  InboxDeregistrationRequests             InboxAgentRegistrationRequest[] @relation("InboxAgentRegistrationRequestDeregistrationWallet")
  apiKeyWalletScopes                      ApiKeyWalletScope[]
  LimitedPurchaseRequests                 PurchaseRequest[]               @relation("HotWalletLimit")
  LowBalanceRules                         HotWalletLowBalanceRule[]
  FundDistributionConfig                  FundDistributionConfig?
  FundDistributionsSent                   FundDistributionRequest[]       @relation("FundDistributionSource")
  FundDistributionsReceived               FundDistributionRequest[]       @relation("FundDistributionTarget")
  hydraRelations                          HydraRelation[]
  hydraLocalParticipants                  HydraLocalParticipant[]
}

model HotWalletLowBalanceRule {
  id              String           @id @default(cuid())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  hotWalletId     String
  assetUnit       String
  thresholdAmount BigInt
  enabled         Boolean          @default(true)
  /// When the balance falls below `thresholdAmount`, this rule always fires the
  /// low-balance alert/webhook. If `topupEnabled` is also set, a fund wallet on
  /// the same source additionally tops the wallet up by `topupAmount` (in the
  /// asset's own smallest unit). The trigger and the amount live here, on the
  /// wallet that runs low, rather than on the treasury.
  topupEnabled    Boolean          @default(false)
  topupAmount     BigInt?
  status          LowBalanceStatus @default(Unknown)
  lastKnownAmount BigInt?
  lastCheckedAt   DateTime?
  lastAlertedAt   DateTime?
  HotWallet       HotWallet        @relation(fields: [hotWalletId], references: [id], onDelete: Cascade)

  @@unique([hotWalletId, assetUnit])
  @@index([hotWalletId, enabled])
  @@index([enabled, status])
}

model Transaction {
  id                                         String                          @id @default(cuid())
  createdAt                                  DateTime                        @default(now())
  updatedAt                                  DateTime                        @updatedAt
  txHash                                     String?
  status                                     TransactionStatus
  confirmations                              Int?
  lastCheckedAt                              DateTime?
  fees                                       BigInt?
  blockHeight                                Int?
  blockTime                                  Int?
  outputAmount                               String?                         @db.Text
  utxoCount                                  Int?
  withdrawalCount                            Int?
  assetMintOrBurnCount                       Int?
  redeemerCount                              Int?
  validContract                              Boolean?
  previousOnChainState                       OnChainState?
  newOnChainState                            OnChainState?
  /// Deterministic txHash (blake2b_256 of the signed tx body) computed BEFORE
  /// broadcast. Set during pre-submit alongside invalidHereafterSlot so the
  /// reconciliation worker can resolve an ambiguous submit (e.g. submit threw
  /// after the node accepted the tx) by querying the chain for this hash. After
  /// successful broadcast txHash and intendedTxHash MUST match.
  intendedTxHash                             String?
  /// The tx's `invalid_hereafter` slot. Once the current slot passes this
  /// (with a small grace), the ledger can never accept the txBody — reconciliation
  /// uses this as the safe boundary to mark an ambiguous Pending tx as
  /// RolledBack and free the wallet without risking double-spend.
  invalidHereafterSlot                       BigInt?
  /// Durable pre-submit context for an L2 reservation. Expiry plus replay
  /// absence is not proof that Hydra rejected the body, so automated recovery
  /// must keep this reservation fail-closed. These fields are retained for an
  /// explicit recovery protocol that can resolve competing outcomes atomically.
  l2ReservationPreviousActionId              String?
  l2ReservationPreviousTransactionId         String?
  l2ReservationPreviousLayer                 TransactionLayer?
  l2ReservationPeerPreviousLayer             TransactionLayer?
  l2ReservationPreviousSmartContractWalletId String?
  l2ReservationPreviousBuyerReturnAddress    String?
  l2ReservationPreviousCollateralReturn      BigInt?
  BlocksWallet                               HotWallet?
  // V2 batch txs: one Transaction row referenced from N PaymentRequests / PurchaseRequests.
  // For V1 single-item txs each list still holds at most one entry, so existing code paths are unchanged.
  PaymentRequestCurrent                      PaymentRequest[]                @relation("CurrentPaymentTransaction")
  PurchaseRequestCurrent                     PurchaseRequest[]               @relation("CurrentPurchaseTransaction")
  RegistryRequest                            RegistryRequest[]
  InboxAgentRegistrationRequest              InboxAgentRegistrationRequest[]
  FundDistributionRequests                   FundDistributionRequest[]       @relation("FundDistributionTransaction")
  FundTransfer                               WalletFundTransfer?             @relation("FundTransferTransaction")
  // History is many-to-many because a V2 batch can move one shared Transaction
  // row through multiple request histories after it leaves CurrentTransaction.
  PaymentRequestHistory                      PaymentRequest[]                @relation("PaymentTransactionHistory")
  PurchaseRequestHistory                     PurchaseRequest[]               @relation("PurchaseTransactionHistory")

  /// Which blockchain layer this transaction was submitted to
  layer TransactionLayer @default(L1)

  /// Hydra head provenance. L2 submissions point at their processing head; the
  /// independently confirmed L1 fanout transaction also retains this link so a
  /// migrated forced-L2 request can continue from its exact L1 handoff without
  /// making fresh forced-L2 requests generically eligible for L1 observation.
  hydraHeadId String?
  HydraHead   HydraHead? @relation(fields: [hydraHeadId], references: [id])

  // Schema-declared full index on intendedTxHash. Migration
  // 20260526002000_add_transaction_intended_tx_hash creates an additional
  // PARTIAL index (`Transaction_intended_pending_idx`) with the predicate
  // `WHERE "txHash" IS NULL AND "intendedTxHash" IS NOT NULL` — that one is
  // the hot-path index for the funding-reconciliation poll and is smaller /
  // tighter than this full index. Prisma cannot express partial indexes in
  // schema.prisma; declaring this full index here ensures `prisma migrate
  // dev` from the schema never silently DROPs index coverage on
  // `intendedTxHash` (it would only drop the partial it doesn't know about
  // and then re-create a full one under a different name). Both indexes
  // co-exist; write cost is acceptable since only ambiguous-funding rows
  // populate this column.
  @@index([intendedTxHash])
  @@index([layer])
  @@index([hydraHeadId])
}

model SwapTransaction {
  id               String            @id @default(cuid())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  txHash           String?
  status           TransactionStatus
  swapStatus       SwapStatus        @default(OrderPending)
  confirmations    Int?
  lastCheckedAt    DateTime?
  fromPolicyId     String
  fromAssetName    String
  fromAmount       String
  toPolicyId       String
  toAssetName      String
  poolId           String
  slippage         Float?
  cancelTxHash     String?
  orderOutputIndex Int?
  hotWalletId      String?
  BlocksWallet     HotWallet?
  HotWallet        HotWallet?        @relation("SwapTransactionHistory", fields: [hotWalletId], references: [id])
}

/// Operator-initiated transfer of funds out of a hot wallet to an arbitrary
/// address. This row is the operator-facing REQUEST and audit record; the
/// on-chain lifecycle lives on the linked Transaction, exactly as
/// FundDistributionRequest does. Reusing Transaction (rather than a private
/// txHash + a pendingFundTransferId lock column) is what makes a fund transfer
/// visible to the shared machinery every other hot-wallet flow already relies
/// on: the stale-lock reaper, funding-reconciliation, and tx-sync rollback all
/// key off Transaction / HotWallet.pendingTransactionId and knew nothing about
/// the parallel columns this model used to own.
model WalletFundTransfer {
  id             String            @id @default(cuid())
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  hotWalletId    String
  toAddress      String
  lovelaceAmount BigInt
  assets         Json?
  /// Denormalized copy of Transaction.txHash, set at submit for cheap display
  /// and history queries. Transaction is the source of truth for the lifecycle.
  txHash         String?
  status         TransactionStatus @default(Pending)
  lastCheckedAt  DateTime?
  errorNote      String?
  /// The Transaction row carrying this transfer's on-chain lifecycle, set
  /// atomically with the hot-wallet lock (HotWallet.pendingTransactionId)
  /// BEFORE the tx is signed or broadcast. One transfer maps to one tx, so this
  /// is unique. onDelete: SetNull keeps the audit row if the tx is ever pruned.
  transactionId  String?           @unique
  Transaction    Transaction?      @relation("FundTransferTransaction", fields: [transactionId], references: [id], onDelete: SetNull)
  HotWallet      HotWallet         @relation("FundTransferHistory", fields: [hotWalletId], references: [id])

  @@index([hotWalletId])
  @@index([status, txHash])
}

model WalletSecret {
  id                String      @id @default(cuid())
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  encryptedMnemonic String
  HotWallet         HotWallet[]
}

model WalletBase {
  id                      String                   @id @default(cuid())
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  walletVkey              String
  note                    String?
  type                    WalletType
  paymentSourceId         String
  walletAddress           String                   @default("")
  PaymentRequest          PaymentRequest[]
  PurchaseRequest         PurchaseRequest[]
  PaymentSource           PaymentSource            @relation(fields: [paymentSourceId], references: [id])
  HydraRelations          HydraRelation[]
  HydraRemoteParticipants HydraRemoteParticipant[]

  @@unique([paymentSourceId, walletVkey, walletAddress, type])
}

model RegistryRequest {
  id                             String                   @id @default(cuid())
  createdAt                      DateTime                 @default(now())
  updatedAt                      DateTime                 @updatedAt
  lastCheckedAt                  DateTime?
  paymentSourceId                String
  smartContractWalletId          String
  recipientHotWalletId           String?
  deregistrationHotWalletId      String?
  sendFundingLovelace            BigInt?
  name                           String
  apiBaseUrl                     String
  capabilityName                 String?
  capabilityVersion              String?
  description                    String?
  privacyPolicy                  String?
  terms                          String?
  other                          String?
  authorName                     String
  authorContactEmail             String?
  authorContactOther             String?
  authorOrganization             String?
  metadataVersion                Int
  tags                           String[]
  agentPricingId                 String                   @unique
  agentIdentifier                String?                  @unique
  state                          RegistrationState
  registrationStateLastChangedAt DateTime                 @default(now())
  currentTransactionId           String?
  error                          String?
  // Consecutive collateral-prep (`prep_tx_failed`) failures for this request.
  // Bounded by MAX_COLLATERAL_PREP_FAILURES: a deterministically-failing prep
  // surfaces as *Failed instead of retrying silently forever. Reset to 0 once
  // collateral prep succeeds (the `ready` gate).
  collateralPrepFailureCount     Int                      @default(0)
  // Nullable: legacy rows created before this column existed have NULL.
  // Deregister/mutate routes treat NULL-owner rows as admin-only.
  requestedById                  String?
  ExampleOutputs                 ExampleOutput[]
  SupportedPaymentSources        SupportedPaymentSource[]
  Verifications                  AgentVerification[]
  Pricing                        AgentPricing             @relation(fields: [agentPricingId], references: [id])
  CurrentTransaction             Transaction?             @relation(fields: [currentTransactionId], references: [id])
  PaymentSource                  PaymentSource            @relation(fields: [paymentSourceId], references: [id])
  SmartContractWallet            HotWallet                @relation("RegistryRequestMintingWallet", fields: [smartContractWalletId], references: [id])
  RecipientWallet                HotWallet?               @relation("RegistryRequestRecipientWallet", fields: [recipientHotWalletId], references: [id])
  DeregistrationHotWallet        HotWallet?               @relation("RegistryRequestDeregistrationWallet", fields: [deregistrationHotWalletId], references: [id])
  RequestedBy                    ApiKey?                  @relation(fields: [requestedById], references: [id])
  X402PaymentAttempts            X402PaymentAttempt[]

  @@index([recipientHotWalletId])
  @@index([deregistrationHotWalletId])
  @@index([requestedById])
}

/// One KERI/Veridian verification claim advertised by a registry entry. Flat,
/// queryable columns (no JSON blob); the nested issuer/schema/credential/holder
/// grouping is reconstructed at the API boundary (see @masumi/payment-core/
/// verification). Emitted into CIP-25 mint/update metadata for trustless,
/// issuer-agnostic third-party verification.
model AgentVerification {
  id                 String          @id @default(cuid())
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  registryRequestId  String
  /// Verification method discriminator, e.g. "KERI-ACDC".
  method             String
  schemaVersion      String?
  /// Issuer KERI AID (ACDC sad.i) + OOBI resolving its KEL.
  issuerAid          String
  issuerOobi         String
  /// Credential schema SAID (ACDC sad.s) + OOBI resolving the JSON schema.
  schemaSaid         String
  schemaOobi         String
  /// Credential SAID (ACDC sad.d) + OOBI serving the signed ACDC.
  credentialSaid     String
  credentialOobi     String
  /// Credential status registry / TEL SAID (ACDC sad.ri) for revocation. Optional.
  credentialRegistry String?
  /// Issuee/holder KERI AID (ACDC sad.a.i) + OOBI resolving its KEL.
  holderAid          String
  holderOobi         String
  /// Optional witness/KERIA resolver root for live key-state and TEL queries.
  baseUrl            String?
  RegistryRequest    RegistryRequest @relation(fields: [registryRequestId], references: [id], onDelete: Cascade)

  @@index([registryRequestId])
}

model SupportedPaymentSource {
  id                String               @id @default(cuid())
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  registryRequestId String
  /// Payment rail / chain family advertised by the registry metadata.
  /// Existing Cardano rows use `Cardano`; standard x402 rows use `EVM`.
  chain             String
  /// Existing Cardano rows keep `Mainnet` / `Preprod` for wire compatibility.
  /// Standard x402 rows use CAIP-2 ids such as `eip155:8453`.
  network           String
  /// Cardano escrow entries keep their PaymentSourceType. Standard x402 rows
  /// are not Masumi escrow PaymentSourceTypes and leave this null.
  paymentSourceType PaymentSourceType?
  address           String
  scheme            X402PaymentScheme?
  asset             String?
  amount            BigInt?
  decimals          Int?
  payTo             String?
  resource          String?
  extra             Json?
  RegistryRequest   RegistryRequest      @relation(fields: [registryRequestId], references: [id], onDelete: Cascade)
  X402Attempts      X402PaymentAttempt[]

  // Partial database unique indexes preserve the legacy Cardano key and the
  // separate x402 key. Prisma cannot model those partial indexes directly.
  @@index([address])
  @@index([paymentSourceType])
  @@index([chain, network])
}

model X402Network {
  id                  String               @id @default(cuid())
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  caip2Id             String               @unique
  displayName         String
  rpcUrl              String
  isTestnet           Boolean              @default(false)
  isEnabled           Boolean              @default(true)
  defaultAsset        String?
  // Facilitator config: EXACTLY ONE of facilitatorWalletId (self-hosted — an owned
  // Selling wallet signs settlements locally) or facilitatorUrl (remote — verify/settle
  // are delegated to an external x402 facilitator over HTTP; the node owns no key here).
  // Enforced at the application layer (a partial DB CHECK cannot span the wallet relation).
  facilitatorWalletId String?
  facilitatorUrl      String?
  // Encrypted auth header value for the remote facilitator (only meaningful with
  // facilitatorUrl); encrypted at rest like other wallet secrets.
  facilitatorAuthEnc  String?
  createdById         String?
  FacilitatorWallet   X402EvmWallet?       @relation("X402NetworkFacilitatorWallet", fields: [facilitatorWalletId], references: [id], onDelete: SetNull)
  CreatedBy           ApiKey?              @relation(fields: [createdById], references: [id], onDelete: SetNull)
  // Wallets bound to this network/payment source (mirrors PaymentSource.HotWallets).
  Wallets             X402EvmWallet[]      @relation("X402NetworkWallets")
  PaymentAttempts     X402PaymentAttempt[]

  @@index([isEnabled])
  @@index([createdById])
}

model X402WalletSecret {
  id                  String          @id @default(cuid())
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  // Public key identity for the encrypted private key. The unique constraint makes
  // concurrent imports of one EVM key converge on one secret across every network.
  address             String          @unique
  encryptedPrivateKey String
  // One secret backs N wallet rows — the same EVM keypair reused across chains.
  Wallets             X402EvmWallet[]
}

model X402EvmWallet {
  id                  String                        @id @default(cuid())
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt
  // Bound to exactly one payment source (network). The SAME EVM keypair on N chains is
  // modelled as N wallet rows (one per network) sharing one X402WalletSecret — mirrors the
  // Cardano HotWallet/WalletSecret split. address is thus unique per network, not globally.
  networkId           String
  secretId            String
  address             String
  type                X402EvmWalletType
  note                String?
  deletedAt           DateTime?
  createdById         String?
  // Cross-instance settle lock, held on the wallet itself — the direct analogue of Cardano's
  // HotWallet.lockedAt. A self-hosted facilitator broadcasts each settle as a tx from this single
  // account, so the account nonce is a shared resource; this row-level lock serializes concurrent
  // settles per facilitator wallet across processes. Set while a settle is in flight, cleared on
  // completion; a stale lock (holder crashed) is stolen after the app's stale timeout. Only ever
  // set on a Selling/facilitator wallet — Purchasing wallets sign offline and never lock.
  lockedAt            DateTime?
  Network             X402Network                   @relation("X402NetworkWallets", fields: [networkId], references: [id], onDelete: Restrict)
  Secret              X402WalletSecret              @relation(fields: [secretId], references: [id])
  CreatedBy           ApiKey?                       @relation(fields: [createdById], references: [id], onDelete: SetNull)
  FacilitatesNetworks X402Network[]                 @relation("X402NetworkFacilitatorWallet")
  Budgets             X402WalletBudget[]
  PaymentAttempts     X402PaymentAttempt[]
  LowBalanceRules     X402EvmWalletLowBalanceRule[]

  @@unique([networkId, address])
  @@index([deletedAt])
  @@index([createdById])
  @@index([type])
  @@index([secretId])
}

model X402EvmWalletLowBalanceRule {
  id              String           @id @default(cuid())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  evmWalletId     String
  // ERC-20 token contract address (lowercased), or the literal "native" for the
  // chain's gas token (ETH). A Selling/facilitator wallet typically monitors "native"
  // (gas to settle); a Purchasing wallet monitors its payment token plus gas. The chain
  // is implied by the wallet's network — no caip2Network column needed here.
  asset           String
  thresholdAmount BigInt
  enabled         Boolean          @default(true)
  status          LowBalanceStatus @default(Unknown)
  lastKnownAmount BigInt?
  lastCheckedAt   DateTime?
  lastAlertedAt   DateTime?
  EvmWallet       X402EvmWallet    @relation(fields: [evmWalletId], references: [id], onDelete: Cascade)

  @@unique([evmWalletId, asset])
  @@index([evmWalletId, enabled])
  @@index([enabled, status])
}

model X402WalletBudget {
  id              String        @id @default(cuid())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  apiKeyId        String
  evmWalletId     String
  // Chain is implied by the wallet's network (EvmWallet.networkId); no caip2Network here.
  asset           String
  remainingAmount BigInt
  spentAmount     BigInt        @default(0)
  // Incremented whenever an admin replaces the grant. In-flight refunds must match the
  // generation they reserved from so they cannot credit a later replacement grant.
  generation      Int           @default(0)
  enabled         Boolean       @default(true)
  createdById     String?
  ApiKey          ApiKey        @relation("X402WalletBudgetGrantee", fields: [apiKeyId], references: [id], onDelete: Cascade)
  CreatedBy       ApiKey?       @relation("X402WalletBudgetCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  EvmWallet       X402EvmWallet @relation(fields: [evmWalletId], references: [id], onDelete: Cascade)

  @@unique([apiKeyId, evmWalletId, asset])
  @@index([apiKeyId, enabled])
  @@index([evmWalletId, enabled])
  @@index([evmWalletId, asset])
  @@index([createdById])
}

model X402PaymentAttempt {
  id                       String                  @id @default(cuid())
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  direction                X402PaymentDirection
  status                   X402PaymentStatus
  apiKeyId                 String
  // The payment source / rail this attempt ran on. Network is structural here (FK to the
  // rail), NOT derived from the wallet: an inbound settle handled by a REMOTE facilitator
  // has no owned wallet, so the rail is the authoritative record of the chain.
  networkId                String
  // Own managed wallet, when the node holds one: outbound → purchasing wallet; inbound with
  // a self-hosted facilitator → the facilitator wallet; inbound with a remote facilitator → null.
  evmWalletId              String?
  // Immutable facilitator-mode snapshot for inbound settles. Null is deliberate for legacy
  // rows whose historical mode cannot be reconstructed truthfully from today's network config.
  facilitatorMode          X402FacilitatorMode?
  // Counterparty (other side) of the transfer: outbound → the payee (payTo); inbound → the
  // payer (buyer), linked after settle once the facilitator reports the address.
  counterpartyWalletId     String?
  registryRequestId        String?
  supportedPaymentSourceId String?
  scheme                   X402PaymentScheme       @default(Exact)
  asset                    String
  amount                   BigInt
  // Immutable recipient snapshot. Inbound attempts must not derive historical payTo
  // solely from SupportedPaymentSource because registry updates replace those rows.
  payTo                    String?
  resource                 String?
  paymentPayloadHash       String?
  paymentPayload           Json?
  paymentIdentifier        String?
  errorReason              String?
  errorMessage             String?
  ApiKey                   ApiKey                  @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  Network                  X402Network             @relation(fields: [networkId], references: [id], onDelete: Restrict)
  EvmWallet                X402EvmWallet?          @relation(fields: [evmWalletId], references: [id], onDelete: Restrict)
  CounterpartyWallet       X402CounterpartyWallet? @relation(fields: [counterpartyWalletId], references: [id], onDelete: Restrict)
  RegistryRequest          RegistryRequest?        @relation(fields: [registryRequestId], references: [id], onDelete: SetNull)
  SupportedPaymentSource   SupportedPaymentSource? @relation(fields: [supportedPaymentSourceId], references: [id], onDelete: SetNull)
  Settlement               X402Settlement?
  // A partial unique index created by migration 20260712000000 permits only one
  // InboundSettle attempt in Verified/Settled state per paymentPayloadHash.
  // Prisma schema syntax cannot represent partial unique indexes.

  @@index([apiKeyId, createdAt])
  @@index([registryRequestId, createdAt])
  @@index([supportedPaymentSourceId])
  @@index([paymentIdentifier])
  @@index([networkId, asset])
  @@index([status, createdAt])
  @@index([evmWalletId])
  @@index([counterpartyWalletId])
  // Settle dedup/crash-window guards look up attempts by paymentPayloadHash
  // (+ direction/status) on every settle; without this they scan the table.
  @@index([paymentPayloadHash])
}

model X402Settlement {
  id                 String             @id @default(cuid())
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  paymentAttemptId   String             @unique
  paymentPayloadHash String             @unique
  success            Boolean
  txHash             String?
  amount             BigInt?
  // network + payer are derivable from the linked attempt (Network.caip2Id) and its
  // CounterpartyWallet; the facilitator-reported originals remain in rawResponse for audit.
  rawResponse        Json?
  PaymentAttempt     X402PaymentAttempt @relation(fields: [paymentAttemptId], references: [id], onDelete: Cascade)

  @@index([txHash])
}

// The counterparty (other side) of an x402 transfer — the EVM analogue of Cardano's
// WalletBase. No vkey: on EVM the address IS the identity. caip2Network is a loose string
// (not an FK) on purpose: a counterparty may sit on a chain this decentralized node does
// not fully configure, and node config can change over time.
model X402CounterpartyWallet {
  id              String               @id @default(cuid())
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  caip2Network    String
  address         String
  role            X402CounterpartyRole
  note            String?
  PaymentAttempts X402PaymentAttempt[]

  @@unique([caip2Network, address, role])
  @@index([address])
}

