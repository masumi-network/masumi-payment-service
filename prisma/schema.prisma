model PaymentSource {
  id                             String                          @id @default(cuid())
  createdAt                      DateTime                        @default(now())
  updatedAt                      DateTime                        @updatedAt
  network                        Network
  lastCheckedAt                  DateTime?
  lastIdentifierChecked          String?
  syncInProgress                 Boolean                         @default(false)
  paymentSourceType              PaymentSourceType               @default(Web3CardanoV1)
  /// Required for Web3CardanoV2 (must be >= 1) and forbidden for Web3CardanoV1.
  /// Enforced at the DB layer by a CHECK constraint defined in migration
  /// 20260524000000_add_payment_source_type_index. Keep this comment in sync if
  /// the constraint is changed.
  requiredAdminSignatures        Int?
  smartContractAddress           String
  /// V1: required fee-receiver (NOT NULL enforced by CHECK
  /// `PaymentSource_v1_admin_wallet_required` in migration
  /// 20260526001000_harden_admin_wallet_constraints).
  /// V2: must be NULL — V2 has no V1-style fee receiver. Enforced by CHECK
  /// `PaymentSource_v2_no_singular_admin` in the same migration.
  adminWalletId                  String?
  feeRatePermille                Int
  cooldownTime                   Int
  paymentSourceConfigId          String                          @unique
  deletedAt                      DateTime?
  /// Registry policy id. Active rows must be unique per network; soft-deleted
  /// rows may keep duplicate historical values. Enforced by the partial unique
  /// index in migration 20260525000000_restore_active_policy_id_uniqueness.
  policyId                       String?
  disablePaymentAt               DateTime?
  disableSyncAt                  DateTime?
  AdminWallets                   AdminWallet[]                   @relation("AdminWallets")
  HotWallets                     HotWallet[]
  PaymentRequests                PaymentRequest[]                @relation("PaymentRequestPaymentSource")
  FeeReceiverNetworkWallet       AdminWallet?                    @relation("FeeReceiverNetworkWallet", fields: [adminWalletId], references: [id], onDelete: SetNull)
  PaymentSourceConfig            PaymentSourceConfig             @relation(fields: [paymentSourceConfigId], references: [id])
  PaymentSourceIdentifiers       PaymentSourceIdentifiers[]
  PurchaseRequests               PurchaseRequest[]               @relation("PurchaseRequestPaymentSource")
  RegistryRequest                RegistryRequest[]
  InboxAgentRegistrationRequests InboxAgentRegistrationRequest[]
  WalletBases                    WalletBase[]
  WebhookEndpoints               WebhookEndpoint[]

  @@unique([network, smartContractAddress])
  // Active-only uniqueness on (network, policyId) is enforced by the partial
  // unique index "PaymentSource_network_policyId_active_key" created in
  // migration 20260525000000_restore_active_policy_id_uniqueness. That index
  // also covers point lookups, so no plain @@index([network, policyId]) is
  // needed (and a duplicate b-tree would waste write throughput).
  @@index([paymentSourceType, deletedAt])
}

model AdminWallet {
  id                       String          @id @default(cuid())
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  walletAddress            String
  paymentSourceAdminId     String?
  /// Canonical V2 admin signing order. Must be unique per
  /// paymentSourceAdminId so the off-chain ordering matches the on-chain
  /// admin_vks list exactly. Enforced by partial unique index
  /// `AdminWallet_paymentSourceAdminId_order_active_key` in migration
  /// 20260526001000_harden_admin_wallet_constraints.
  order                    Int
  /// V2 admin-set membership. FK is ON DELETE RESTRICT (migration
  /// 20260526001000_harden_admin_wallet_constraints) so an admin must be
  /// detached (paymentSourceAdminId set to NULL) before deletion. A
  /// deferrable trigger also enforces count(AdminWallets) >=
  /// requiredAdminSignatures for V2 PaymentSources.
  PaymentSourceAdmin       PaymentSource?  @relation("AdminWallets", fields: [paymentSourceAdminId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  PaymentSourceFeeReceiver PaymentSource[] @relation("FeeReceiverNetworkWallet")
}

