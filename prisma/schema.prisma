model PurchaseRequest {
  id                                            String               @id @default(cuid())
  createdAt                                     DateTime             @default(now())
  updatedAt                                     DateTime             @updatedAt
  lastCheckedAt                                 DateTime?
  paymentSourceId                               String
  sellerWalletId                                String
  smartContractWalletId                         String?
  metadata                                      String?
  pricingType                                   PricingType          @default(Fixed)
  blockchainIdentifier                          String               @unique
  /// Decoded agent asset id (policyId + asset name hex); denormalized for search. Mirrors decodeBlockchainIdentifier(..).agentIdentifier.
  agentIdentifier                               String?
  /// Populated when agentIdentifier was aligned from blockchainIdentifier (create path or startup backfill). Null only on legacy rows pending sync.
  agentIdentifierSyncedAt                       DateTime?
  /// Denormalized agent display name for search; snapshot at create/backfill from registry or on-chain metadata.
  agentName                                     String?
  /// Populated when agentName was aligned (create path or startup backfill). Null only on legacy rows pending sync.
  agentNameSyncedAt                             DateTime?
  submitResultTime                              BigInt
  unlockTime                                    BigInt
  externalDisputeUnlockTime                     BigInt
  inputHash                                     String
  resultHash                                    String?
  onChainState                                  OnChainState?
  onChainStateOrResultLastChangedAt             DateTime             @default(now())
  sellerCoolDownTime                            BigInt
  buyerCoolDownTime                             BigInt
  totalBuyerCardanoFees                         BigInt               @default(0)
  totalSellerCardanoFees                        BigInt               @default(0)
  nextActionId                                  String               @unique
  nextActionLastChangedAt                       DateTime             @default(now())
  nextActionOrOnChainStateOrResultLastChangedAt DateTime             @default(now())
  requestedById                                 String
  // Not @unique: V2 batch transactions reference one shared Transaction row from N PurchaseRequests.
  // Uniqueness was a leftover from the V1 single-item flow; dropping it allows
  // a multi-redeemer batch tx to be referenced once from each participating request.
  currentTransactionId                          String?
  collateralReturnLovelace                      BigInt?
  payByTime                                     BigInt?
  buyerReturnAddress                            String?
  sellerReturnAddress                           String?
  CurrentTransaction                            Transaction?         @relation("CurrentPurchaseTransaction", fields: [currentTransactionId], references: [id])
  NextAction                                    PurchaseActionData   @relation("NextAction", fields: [nextActionId], references: [id])
  ActionHistory                                 PurchaseActionData[] @relation("PurchaseActionHistory")
  PaymentSource                                 PaymentSource        @relation("PurchaseRequestPaymentSource", fields: [paymentSourceId], references: [id], onDelete: Cascade)
  requestedBy                                   ApiKey               @relation(fields: [requestedById], references: [id])
  SellerWallet                                  WalletBase           @relation(fields: [sellerWalletId], references: [id], onDelete: Cascade)
  SmartContractWallet                           HotWallet?           @relation(fields: [smartContractWalletId], references: [id])
  isLimitedToHotWallets                         Boolean
  HotWalletLimit                                HotWallet[]          @relation("HotWalletLimit")
  TransactionHistory                            Transaction[]        @relation("PurchaseTransactionHistory")
  WithdrawnForBuyer                             UnitValue[]          @relation("BuyerWithdrawnPurchaseRequest")
  PaidFunds                                     UnitValue[]
  WithdrawnForSeller                            UnitValue[]          @relation("SellerWithdrawnPurchaseRequest")

  /// Which blockchain layer this request targets
  layer TransactionLayer @default(L1)

  @@index([nextActionLastChangedAt])
  @@index([nextActionLastChangedAt, id])
  @@index([onChainStateOrResultLastChangedAt])
  @@index([onChainStateOrResultLastChangedAt, id])
  @@index([nextActionOrOnChainStateOrResultLastChangedAt], map: "PurchaseRequest_combinedLastChangedAt_idx")
  @@index([nextActionOrOnChainStateOrResultLastChangedAt, id], map: "PurchaseRequest_combinedLastChangedAt_id_idx")
  @@index([paymentSourceId, createdAt])
  @@index([paymentSourceId, onChainState])
  @@index([paymentSourceId, payByTime])
  @@index([currentTransactionId])
  @@index([layer])
}

