// Webhook models
model WebhookEndpoint {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  url       String
  authToken String
  events    WebhookEventType[]
  name      String?

  PaymentSource   PaymentSource? @relation(fields: [paymentSourceId], references: [id], onDelete: Cascade)
  paymentSourceId String?

  CreatedByApiKey   ApiKey? @relation(fields: [createdByApiKeyId], references: [id], onDelete: SetNull)
  createdByApiKeyId String?

  isActive            Boolean   @default(true)
  failureCount        Int       @default(0)
  consecutiveFailures Int       @default(0)
  lastSuccessAt       DateTime?
  disabledAt          DateTime?

  WebhookDeliveries WebhookDelivery[]
}

model WebhookDelivery {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  WebhookEndpoint   WebhookEndpoint @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)
  webhookEndpointId String

  eventType WebhookEventType
  payload   Json
  entityId  String?

  status      WebhookDeliveryStatus @default(Pending)
  attempts    Int                   @default(0)
  maxAttempts Int                   @default(3)
  nextRetryAt DateTime?

  responseCode Int?
  errorMessage String?
  deliveredAt  DateTime?
  durationMs   Int?
}

enum WebhookEventType {
  PURCHASE_ON_CHAIN_STATUS_CHANGED
  PAYMENT_ON_CHAIN_STATUS_CHANGED
  PURCHASE_ON_ERROR
  PAYMENT_ON_ERROR
}

enum WebhookDeliveryStatus {
  Pending
  Success
  Failed
  Retrying
  Cancelled
}

// ============================================================
// HYDRA L2 MODELS
// ============================================================

enum HydraHeadStatus {
  Idle
  Initializing
  Open
  Closed
  FanoutPossible
  Final
}

/// Persistent relation between exactly 2 HotWallets for Hydra L2.
/// This is the lookup key for routing decisions: "is there a head between wallet X and wallet Y?"
/// Each relation can have multiple HydraHead records over time (one closes, a new one opens).
///
/// Wallets are stored in deterministic order (walletIdA < walletIdB lexicographically)
/// so the same pair is never duplicated with swapped columns.
/// The buyer/seller role is not encoded here — it is resolved from HotWallet.type at query time.
model HydraRelation {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  /// Cardano network this relation operates on
  network   Network

  /// First wallet (lexicographically smaller HotWallet ID)
  walletIdA String
  /// Second wallet (lexicographically larger HotWallet ID)
  walletIdB String
  WalletA   HotWallet @relation("HydraRelationWalletA", fields: [walletIdA], references: [id], onDelete: Restrict)
  WalletB   HotWallet @relation("HydraRelationWalletB", fields: [walletIdB], references: [id], onDelete: Restrict)

  /// Individual head sessions within this relation (1:N)
  Heads     HydraHead[]

  /// One relation per wallet pair per network
  @@unique([network, walletIdA, walletIdB])

  /// Primary lookup: find relation between two specific wallets
  @@index([walletIdA, walletIdB])

  /// Reverse lookup
  @@index([walletIdB, walletIdA])
}

/// A single Hydra head instance within a participant relation.
/// Each head is one "session" — it goes through Idle → Open → Closed → Final.
/// A relation can have many heads over its lifetime, but typically only one is Open.
model HydraHead {
  id                   String             @id @default(cuid())
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  /// The participant relation this head belongs to
  hydraRelationId      String
  HydraRelation        HydraRelation      @relation(fields: [hydraRelationId], references: [id], onDelete: Restrict)

  /// Hydra protocol head ID (assigned by Hydra node after Init)
  headId               String?            @unique

  /// Current status of the Hydra head
  status               HydraHeadStatus    @default(Idle)

  /// Contestation period in seconds (configured on the Hydra node)
  contestationPeriod   Int                @default(60)

  /// Lifecycle timestamps
  openedAt             DateTime?
  closedAt             DateTime?
  finalizedAt          DateTime?

  /// Deadline after which fanout is possible (set when head is closed)
  contestationDeadline DateTime?

  /// Latest activity timestamp for idle detection / auto-close
  latestActivityAt     DateTime?

  /// Latest confirmed snapshot number (monotonically increasing while head is open)
  latestSnapshotNumber Int                @default(0)

  /// L1 transaction hashes for head lifecycle events
  initTxHash           String?
  closeTxHash          String?
  fanoutTxHash         String?

  /// Last error message (if any)
  lastError            String?
  lastErrorAt          DateTime?

  /// Participants in this head (node config, keys per head)
  Participants         HydraParticipant[]

  /// Transactions submitted through this head (L2)
  Transactions         Transaction[]

  @@index([status])
  @@index([hydraRelationId, status])
}

/// A participant in a Hydra head.
/// Each head has exactly 2 participants (matching the relation).
/// Node URLs and keys can differ per head, so they live here, not on the relation.
model HydraParticipant {
  id                     String                @id @default(cuid())
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  /// Which head this participant belongs to
  hydraHeadId            String
  HydraHead              HydraHead             @relation(fields: [hydraHeadId], references: [id], onDelete: Restrict)

  /// The HotWallet this participant represents
  walletId               String
  Wallet                 HotWallet             @relation("HydraParticipantWallet", fields: [walletId], references: [id], onDelete: Restrict)

  /// Participant order/index in the head (0-based)
  participantIndex       Int

  /// WebSocket URL for this participant's Hydra node (e.g. ws://127.0.0.1:4001)
  nodeUrl                String

  /// HTTP URL for this participant's Hydra node (e.g. http://127.0.0.1:4001)
  nodeHttpUrl            String

  /// Cardano verification key for this participant in the head
  cardanoVerificationKey String?

  /// Hydra verification key for this participant in the head
  hydraVerificationKey   String?

  /// Whether this participant has committed funds to the head
  hasCommitted           Boolean               @default(false)

  /// L1 commit transaction hash (set after this participant commits to the head)
  commitTxHash           String?

  /// Encrypted key material for operating this participant's Hydra node (1:1)
  hydraSecretId          String?               @unique
  HydraSecret            HydraSecret?          @relation(fields: [hydraSecretId], references: [id])

  /// Same wallet cannot join the same head twice
  @@unique([hydraHeadId, walletId])

  /// Index for "find all heads where a wallet is involved"
  @@index([walletId])
  @@index([walletId, hydraHeadId])
}

/// Encrypted Hydra signing key for a participant (1:1 with HydraParticipant).
/// Fund and node wallet keys are not needed here — those come from the HotWallet.
/// Uses the project's encrypt()/decrypt() from @/utils/security/encryption.
model HydraSecret {
  id                      String            @id @default(cuid())
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  /// Encrypted Hydra signing key (cborHex of the signing key)
  hydraSK                 String

  HydraParticipant        HydraParticipant?
}

