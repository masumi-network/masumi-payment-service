// Webhook models
model WebhookEndpoint {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  url       String
  urlHash   String?
  authToken String?
  format    WebhookFormat      @default(EXTENDED)
  events    WebhookEventType[]
  name      String?

  PaymentSource   PaymentSource? @relation(fields: [paymentSourceId], references: [id], onDelete: Cascade)
  paymentSourceId String?

  CreatedByApiKey   ApiKey? @relation(fields: [createdByApiKeyId], references: [id], onDelete: SetNull)
  createdByApiKeyId String?

