    "@types/node": "25.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.2",
    "eslint-config-next": "16.1.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "postcss": "8.5.15",
    "prettier": "3.8.4",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3"
  }
