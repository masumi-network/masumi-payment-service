{
	"compilerOptions": {
		"module": "ES2022",
		"moduleResolution": "node",
		"esModuleInterop": true,
		"pretty": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"target": "es2021",
		"outDir": "./dist",
		"baseUrl": ".",
		"experimentalDecorators": true,
		"strict": true,
		"allowSyntheticDefaultImports": true,
		"paths": {
			"@/*": ["src/*"],
			"@masumi/payment-core": ["packages/payment-core/src/index.ts"],
			"@masumi/payment-core/*": ["packages/payment-core/src/*"],
			"@masumi/payment-source-v1": ["packages/payment-source-v1/src/index.ts"],
			"@masumi/payment-source-v2": ["packages/payment-source-v2/src/index.ts"],
			"@smart-contracts/*": ["smart-contracts/*"],
			"@prisma/client": ["src/generated/prisma/client"]
		}
	},
	"include": [
		"src/**/*.ts",
		"packages/**/*.ts",
		"smart-contracts/**/plutus.json",
		"tests/**/*.ts",
		"jest.e2e*.config.ts",
		"scripts/**/*.ts"
	],
	"exclude": ["node_modules"]
}
